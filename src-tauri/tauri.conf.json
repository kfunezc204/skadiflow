{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SkadiFlow",
  "version": "0.1.0",
  "identifier": "com.kevin.skadiflow",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SkadiFlow",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 768,
        "center": true,
        "decorations": false,
        "resizable": true,
        "label": "main"
      },
      {
        "label": "floating-timer",
        "title": "SkadiFlow Timer",
        "url": "/#/floating-timer",
        "width": 340,
        "height": 88,
        "minWidth": 340,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "visible": false,
        "skipTaskbar": true,
        "backgroundColor": [0, 0, 0, 0]
      },
      {
        "label": "task-toast",
        "title": "SkadiFlow Notification",
        "url": "/#/task-toast",
        "width": 360,
        "height": 84,
        "minWidth": 360,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "visible": false,
        "skipTaskbar": true,
        "backgroundColor": [0, 0, 0, 0]
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob: asset: https://asset.localhost; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; script-src 'self'; connect-src 'self' ipc: https://ipc.localhost ws://localhost:* http://localhost:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
